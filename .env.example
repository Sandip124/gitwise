# SQLite database path (default: ~/.wisegit/wisegit.db)
# WISEGIT_DB_PATH=~/.wisegit/wisegit.db

# Issue enrichment — API tokens for fetching issue/PR context
# GitHub: 5000 req/hr authenticated vs 60 unauthenticated
# GITHUB_TOKEN=ghp_...
# GH_TOKEN=ghp_...

# GitLab
# GITLAB_TOKEN=glpat-...

# Ollama (local LLM — Phase 2)
OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3
OLLAMA_EMBED_MODEL=nomic-embed-text
